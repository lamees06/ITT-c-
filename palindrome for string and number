#include<iostream>
#include<cstring>
using namespace std;
void check(const char str[])
{
   int len=strlen(str);
   bool ispalindrome=true;
   for(int i=0;i<len/2;i++)
   {
      if(str[i]!=str[len-i-1])
      {
         ispalindrome=false;
         break;
      }
   }
   if(ispalindrome)
   {
      cout<<str<<" is a palindrome"<<endl;
   }
   else
   {
      cout<<str<<" is not a palindrome"<<endl;
   }
}
void check(int num)
{
   int original=num;
   int rev=0;
   while(num>0)
   {
      int digit=num%10;
      rev=rev*10+digit;
      num/=10;
   }
   if(original==rev)
   {
      cout<<original<<" is a palindrome"<<endl;
   }
   else
   {
      cout<<original<<" is not a palindrome"<<endl;
   }
}
int main()
{
   char str[100];
   cout<<"Enter a string: ";
   cin>>str;
   check(str);
   int num;
   cout<<"Enter a number: ";
   cin>>num;
   check(num);
   return 0;
}
