#include <iostream>
using namespace std;
class Matrix {
    int a[2][2];
public:
    Matrix()
    {
        for(int i=0;i<2;i++)
            for(int j=0;j<2;j++)
               a[i][j] = 0;
    }
    void input()
    {
        for(int i=0;i<2;i++)
            for(int j=0;j<2;j++)
            {
               cin>>a[i][j];
            }
    }
    Matrix operator+(Matrix m)
    {
        Matrix temp;
        for(int i=0;i<2;i++)
            for(int j=0;j<2;j++)
            {
                temp.a[i][j] = a[i][j] + m.a[i][j];
            }
        return temp;
    }
    Matrix operator*(Matrix m)
    {
        Matrix temp;
        for(int i=0;i<2;i++)
            for(int j=0;j<2;j++)
                for(int k=0;k<2;k++)
                    temp.a[i][j] += a[i][k] * m.a[k][j];
        return temp;
    }
    void display()
    {
        for(int i=0;i<2;i++)
        {
            for(int j=0;j<2;j++)
               cout<<a[i][j]<<" ";
            cout<<endl;
        }
    }
};
int main()
{
    Matrix m1,m2,resSum,resMult;
    cout<<"Enter Matrix 1 (2x2):\n";
    m1.input();
    cout<<"Enter Matrix 2 (2x2):\n";
    m2.input();
    resSum = m1 + m2;
    resMult = m1 * m2;
    cout<<"\nSum: "<<endl;
    resSum.display();
    cout << "Product: "<<endl;
    resMult.display();
    return 0;
}
